# BigLaw Legal Epistemic Ontology (BLEO)
# Canonical spec. The Go package in this directory (ontology.go) encodes the
# vocabulary below; evidencegraph stores Claims validated against it.
#
# Three layers:
#   Domain    — what the matter is about (typed parties, conduct, authority, quantities)
#   Epistemic — claims ABOUT the domain (provenance, grounding, status, dialectic) — the heart
#   Analytic  — legal reasoning (concepts, elements, derived defense issues)
#
# The point: BigLaw's agents are epistemic actors. They PRODUCE, GROUND, CHALLENGE,
# VERIFY, and CONSUME claims. Every agent reads/writes this one graph; epistemic
# status drives synthesis. domain/range typing rejects the extractor's noise
# (predicate-direction flips, mis-typed objects, sentence-nodes).

@prefix bleo: <https://discover.legal/ns/bleo#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

bleo: a owl:Ontology ;
    rdfs:label "BigLaw Legal Epistemic Ontology" ;
    owl:versionInfo "0.1.0" .

############################################################
# LAYER 1 — DOMAIN
############################################################

# --- Classes ---
bleo:Party      a owl:Class ; rdfs:label "Party" .
bleo:Person     a owl:Class ; rdfs:subClassOf bleo:Party .
bleo:Firm       a owl:Class ; rdfs:subClassOf bleo:Party .
bleo:Fund       a owl:Class ; rdfs:subClassOf bleo:Party .
bleo:Account    a owl:Class ; rdfs:subClassOf bleo:Party .
bleo:Broker     a owl:Class ; rdfs:subClassOf bleo:Party .
bleo:Client     a owl:Class ; rdfs:subClassOf bleo:Party .

bleo:Conduct    a owl:Class ; rdfs:label "Conduct" ;
    rdfs:comment "A named wrongful scheme, violation, or omission — the unit an allegation is built around." .
bleo:Scheme     a owl:Class ; rdfs:subClassOf bleo:Conduct .
bleo:Violation  a owl:Class ; rdfs:subClassOf bleo:Conduct .
bleo:Omission   a owl:Class ; rdfs:subClassOf bleo:Conduct .

bleo:Authority  a owl:Class ; rdfs:label "Legal Authority" .
bleo:Statute    a owl:Class ; rdfs:subClassOf bleo:Authority .
bleo:Rule       a owl:Class ; rdfs:subClassOf bleo:Authority .
bleo:Provision  a owl:Class ; rdfs:subClassOf bleo:Authority .
bleo:Obligation a owl:Class ; rdfs:subClassOf bleo:Authority .
bleo:Standard   a owl:Class ; rdfs:subClassOf bleo:Authority .

bleo:Instrument a owl:Class ; rdfs:label "Instrument" .
bleo:Filing        a owl:Class ; rdfs:subClassOf bleo:Instrument .
bleo:Exhibit       a owl:Class ; rdfs:subClassOf bleo:Instrument .
bleo:Agreement     a owl:Class ; rdfs:subClassOf bleo:Instrument .
bleo:Communication a owl:Class ; rdfs:subClassOf bleo:Instrument .

bleo:Quantity   a owl:Class ; rdfs:label "Quantity" .
bleo:Money       a owl:Class ; rdfs:subClassOf bleo:Quantity .
bleo:Percentage  a owl:Class ; rdfs:subClassOf bleo:Quantity .
bleo:Count       a owl:Class ; rdfs:subClassOf bleo:Quantity .
bleo:Date        a owl:Class ; rdfs:subClassOf bleo:Quantity .
bleo:Identifier  a owl:Class ; rdfs:subClassOf bleo:Quantity .

bleo:Event        a owl:Class ; rdfs:label "Event" .
bleo:Jurisdiction a owl:Class ; rdfs:label "Jurisdiction" .
bleo:Matter       a owl:Class ; rdfs:label "Matter" .

# --- Domain object properties (controlled predicates, with domain/range) ---
# Validation: a triple whose subject/object class is incompatible with the
# predicate's domain/range is rejected or re-oriented (kills direction flips).
bleo:committedBy a owl:ObjectProperty ;
    rdfs:domain bleo:Conduct ; rdfs:range bleo:Party .
bleo:violates a owl:ObjectProperty ;
    rdfs:domain bleo:Conduct ; rdfs:range bleo:Authority .
bleo:harmed a owl:ObjectProperty ;
    rdfs:domain bleo:Conduct ; rdfs:range bleo:Party .
bleo:quantifiedAs a owl:ObjectProperty ;
    rdfs:domain [ owl:unionOf ( bleo:Conduct bleo:Party ) ] ; rdfs:range bleo:Quantity .
bleo:ownsStakeIn a owl:ObjectProperty ;
    rdfs:domain bleo:Party ; rdfs:range bleo:Party .
bleo:receivedFrom a owl:ObjectProperty ;
    rdfs:domain bleo:Party ; rdfs:range bleo:Party .
bleo:failedToDisclose a owl:ObjectProperty ;
    rdfs:domain bleo:Party .
bleo:directedTradesTo a owl:ObjectProperty ;
    rdfs:domain bleo:Party ; rdfs:range bleo:Broker .
bleo:heldAccountAt a owl:ObjectProperty ;
    rdfs:domain bleo:Party ; rdfs:range bleo:Broker .
bleo:alteredRecords a owl:ObjectProperty ;
    rdfs:domain bleo:Party ; rdfs:range bleo:Instrument .
bleo:occurredDuring a owl:ObjectProperty ;
    rdfs:domain bleo:Conduct ; rdfs:range bleo:Event .
bleo:citedIn a owl:ObjectProperty ;
    rdfs:range bleo:Instrument .
bleo:hasRole a owl:DatatypeProperty ;
    rdfs:domain bleo:Party ; rdfs:range xsd:string .

############################################################
# LAYER 2 — EPISTEMIC  (claims about the domain)
############################################################

bleo:Claim a owl:Class ; rdfs:label "Claim" ;
    rdfs:comment "A reified domain proposition with provenance, grounding, status, and dialectic." .

# What it asserts (reification of a domain triple)
bleo:claimSubject   a owl:ObjectProperty ; rdfs:domain bleo:Claim .
bleo:claimPredicate a owl:DatatypeProperty ; rdfs:domain bleo:Claim ; rdfs:range xsd:string .
bleo:claimObject    a owl:ObjectProperty ; rdfs:domain bleo:Claim .
bleo:about          a owl:ObjectProperty ; rdfs:domain bleo:Claim ; rdfs:range bleo:Conduct .

# Provenance — WHO asserts it (legal actor) and which agent extracted it
bleo:LegalActor a owl:Class .
bleo:Accuser    a owl:Class ; rdfs:subClassOf bleo:LegalActor .   # SEC / Division
bleo:Respondent a owl:Class ; rdfs:subClassOf bleo:LegalActor .   # the defense
bleo:Court      a owl:Class ; rdfs:subClassOf bleo:LegalActor .
bleo:ThirdParty a owl:Class ; rdfs:subClassOf bleo:LegalActor .
bleo:assertedBy   a owl:ObjectProperty ; rdfs:domain bleo:Claim ; rdfs:range bleo:LegalActor .
bleo:extractedBy  a owl:DatatypeProperty ; rdfs:domain bleo:Claim ; rdfs:range xsd:string . # BigLaw agent id
bleo:practiceArea a owl:DatatypeProperty ; rdfs:domain bleo:Claim ; rdfs:range xsd:string .
bleo:inRound      a owl:DatatypeProperty ; rdfs:domain bleo:Claim ; rdfs:range xsd:integer .

# Grounding (CitationGate) — verbatim span in a source instrument
bleo:groundedIn   a owl:ObjectProperty ; rdfs:domain bleo:Claim ; rdfs:range bleo:Instrument .
bleo:quote        a owl:DatatypeProperty ; rdfs:domain bleo:Claim ; rdfs:range xsd:string .
bleo:source       a owl:DatatypeProperty ; rdfs:domain bleo:Claim ; rdfs:range xsd:string .

# Epistemic status (the lifecycle) + modality + confidence
bleo:epistemicStatus a owl:DatatypeProperty ; rdfs:domain bleo:Claim ; rdfs:range bleo:Status .
bleo:Status a owl:Class .
bleo:Hypothesized a bleo:Status . bleo:Alleged a bleo:Status . bleo:Asserted a bleo:Status .
bleo:Grounded a bleo:Status . bleo:Corroborated a bleo:Status . bleo:Contested a bleo:Status .
bleo:Verified a bleo:Status . bleo:Refuted a bleo:Status . bleo:Unverified a bleo:Status .
bleo:modality   a owl:DatatypeProperty ; rdfs:domain bleo:Claim ; rdfs:range xsd:string . # alleged|established|disputed|inferred|admitted
bleo:confidence a owl:DatatypeProperty ; rdfs:domain bleo:Claim ; rdfs:range xsd:decimal .
bleo:standardOfProof a owl:DatatypeProperty ; rdfs:domain bleo:Claim ; rdfs:range xsd:string .

# Dialectic — Claim → Claim stance edges (the debate graph; contradiction detector writes `contradicts`)
bleo:supports     a owl:ObjectProperty ; rdfs:domain bleo:Claim ; rdfs:range bleo:Claim .
bleo:corroborates a owl:ObjectProperty ; rdfs:domain bleo:Claim ; rdfs:range bleo:Claim .
bleo:contradicts  a owl:ObjectProperty ; rdfs:domain bleo:Claim ; rdfs:range bleo:Claim .
bleo:rebuts       a owl:ObjectProperty ; rdfs:domain bleo:Claim ; rdfs:range bleo:Claim .
bleo:qualifies    a owl:ObjectProperty ; rdfs:domain bleo:Claim ; rdfs:range bleo:Claim .
bleo:undercuts    a owl:ObjectProperty ; rdfs:domain bleo:Claim ; rdfs:range bleo:Claim .

# Verification / challenge provenance
bleo:verifiedBy   a owl:DatatypeProperty ; rdfs:domain bleo:Claim ; rdfs:range xsd:string .
bleo:challengedBy a owl:DatatypeProperty ; rdfs:domain bleo:Claim ; rdfs:range xsd:string .

############################################################
# LAYER 3 — ANALYTIC  (legal reasoning)
############################################################

bleo:LegalConcept a owl:Class ; rdfs:label "Legal Concept" ;
    rdfs:comment "Cross-domain concept owned by a Conceptual agent (scienter, materiality, fiduciary duty, statute of limitations, respondeat superior, best execution)." .
bleo:implicates      a owl:ObjectProperty ; rdfs:domain [ owl:unionOf ( bleo:Claim bleo:Conduct ) ] ; rdfs:range bleo:LegalConcept .
bleo:requiresElement a owl:ObjectProperty ; rdfs:domain bleo:Authority ; rdfs:range bleo:LegalConcept .
bleo:satisfiesElement a owl:ObjectProperty ; rdfs:domain bleo:Claim ; rdfs:range bleo:LegalConcept .

bleo:DefenseIssue a owl:Class ; rdfs:label "Defense Issue" ;
    rdfs:comment "Derived: a discrepancy (contradicts-pair), an element gap (requiresElement with no satisfiesElement), or a time-bar (Event outside an SOL window)." .
bleo:DiscrepancyIssue a owl:Class ; rdfs:subClassOf bleo:DefenseIssue .
bleo:ElementGapIssue  a owl:Class ; rdfs:subClassOf bleo:DefenseIssue .
bleo:LimitationsIssue a owl:Class ; rdfs:subClassOf bleo:DefenseIssue .
bleo:raisesIssue   a owl:ObjectProperty ; rdfs:range bleo:DefenseIssue .
bleo:significance  a owl:DatatypeProperty ; rdfs:domain bleo:DefenseIssue ; rdfs:range xsd:string .
