{
  "name": "big-michael",
  "version": "0.4.0",
  "description": "Big Michael — portable multi-agent legal AI orchestration. Sits atop and within Mike (AGPL-3.0), Lavern (Apache-2.0), and others. DyTopo rounds, RuVector registry, Anthropic + Ollama inference, PyMuPDF/Camelot/Tesseract document tools, MCP + REST.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && copyfiles -u 1 \"src/templates/*.json\" dist",
    "start": "node dist/index.js",
    "dev": "tsx watch --ignore \"**/.tasks.json\" --ignore \"**/audit.jsonl\" --ignore \"output/**\" --ignore \"data/**\" src/index.ts",
    "serve": "cross-env BIG_MICHAEL_MODE=backend tsx watch --ignore \"**/.tasks.json\" --ignore \"**/audit.jsonl\" --ignore \"output/**\" --ignore \"data/**\" src/index.ts",
    "seed": "tsx src/scripts/seed.ts",
    "smoke-test": "cross-env ANTHROPIC_API_KEY=smoke-test OPENAI_API_KEY=smoke-test tsx src/scripts/smoke-test.ts",
    "test": "cross-env ANTHROPIC_API_KEY=test OPENAI_API_KEY=test tsx --test tests/unit.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@tavily/core": "^0.7.3",
    "@tgwf/co2": "^0.18.0",
    "docx": "^9.7.1",
    "dotenv": "^16.4.5",
    "fast-diff": "^1.3.0",
    "fast-xml-parser": "^5.8.0",
    "fastify": "^5.8.5",
    "openai": "^4.67.0",
    "ruvector": "^0.2.27",
    "uuid": "^11.1.1",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "copyfiles": "^2.4.1",
    "cross-env": "^10.1.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0"
  }
}
