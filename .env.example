# LLM
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Embeddings (OpenAI; swap for Voyage AI: VOYAGE_API_KEY + model voyage-3-lite)
# Not required when LOCAL_EMBEDDINGS=true
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Local inference — Ollama (https://ollama.com)
# OLLAMA_ENABLED=true routes OLLAMA_TIERS agents to local Ollama.
# Pull a model first: ollama pull llama3.2
# For tool-use: ollama pull llama3.1   or  ollama pull qwen2.5
#
OLLAMA_ENABLED=false
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIERS=3
LOCAL_EMBEDDINGS=false
# Embedding model served by Ollama. Recommended: nomic-embed-text (768-dim)
# Also supported: mxbai-embed-large (1024-dim), or any Ollama-hosted model
LOCAL_EMBEDDING_MODEL=nomic-embed-text

# Generic local inference — any OpenAI-compat server (LM Studio, Jan, vLLM, llama.cpp)
# Set LOCAL_INFERENCE_URL to activate; LOCAL_INFERENCE_TIERS=all routes everything locally.
#
# LM Studio example:
#   LOCAL_INFERENCE_URL=http://localhost:1234/v1
#   LOCAL_INFERENCE_MODEL=llama-3.2-3b-instruct
#   LOCAL_INFERENCE_TIERS=all
#
# Jan example:
#   LOCAL_INFERENCE_URL=http://localhost:1337/v1
#   LOCAL_INFERENCE_MODEL=llama3-8b-instruct
#   LOCAL_INFERENCE_TIERS=2,3
#
# vLLM / llama.cpp server example:
#   LOCAL_INFERENCE_URL=http://gpu-server:8000/v1
#   LOCAL_INFERENCE_KEY=your-key-if-any
#   LOCAL_INFERENCE_MODEL=Meta-Llama-3.1-70B-Instruct
#   LOCAL_INFERENCE_TIERS=all
#
LOCAL_INFERENCE_URL=
LOCAL_INFERENCE_KEY=local
LOCAL_INFERENCE_MODEL=local-model
LOCAL_INFERENCE_TIERS=

# PDF tools — PyMuPDF (text extraction + document generation) + Camelot (tables)
# System requirements: Python 3.11+, PyMuPDF >= 1.23, camelot-py[base]
# Install: pip install "pymupdf>=1.23" "camelot-py[base]"
# For bordered-table extraction (lattice mode): pip install "camelot-py[cv]"
PDF_PYTHON_BIN=python3
PDF_OUTPUT_DIR=./output/documents

# Vector DB (Qdrant dev stand-in; swap URL for RuVector: https://github.com/ruvnet/RuVector)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# MCP / REST
MCP_PORT=3100
API_PORT=3101

# DyTopo
DYTOPO_SIMILARITY_THRESHOLD=0.68
DYTOPO_MAX_AGENTS_PER_ROUND=12
DYTOPO_MAX_ROUNDS=14

# Debate protocol
DEBATE_CITATION_REQUIRED=true
DEBATE_ADVERSARIAL_ENABLED=true
DEBATE_VERIFICATION_PASSES=10
DEBATE_GATE_CONFIDENCE_THRESHOLD=0.80

# Web search (Tavily — https://tavily.com, free tier available)
TAVILY_API_KEY=

# Task persistence — path to JSON file for task state across restarts
TASKS_FILE=.tasks.json

# Audit log — append-only JSONL; every inference call, tool call, gate, debate is recorded
# Set AUDIT_ENABLED=false to disable disk writes (in-memory buffer always active)
AUDIT_ENABLED=true
AUDIT_LOG_FILE=./audit.jsonl

# Logging
LOG_LEVEL=info
