# ─────────────────────────────────────────────────────────────────────────────
# .env.example — LOCAL DEVELOPMENT ONLY
#
# In production, environment variables come from your host (container env,
# Kubernetes secrets, AWS ECS task definitions, etc.). No .env file is needed.
#
# With Infisical (recommended): only the INFISICAL_* bootstrap vars at the
# bottom of this file need to be set locally. Everything else — QWEN_API_KEY,
# connector keys, session secrets — is fetched from Infisical at startup and
# injected into process.env before any application code runs.
#
# Without Infisical: set the vars you need directly here for local dev.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Primary model stack ──────────────────────────────────────────────────────
# The platform default is Qwen (Alibaba) over DashScope's OpenAI-compatible API.
# This build ships free of any Anthropic dependency by design; it will refuse to
# start if pointed at an Anthropic endpoint or a Claude model. Four tiers plus a
# vision tier for omnimodal document extraction:
#   Heavy  → synthesis / debate / root orchestrator / high-complexity reasoning
#   Mid    → managers, specialists, drafting, document-extraction reconcile (default)
#   Light  → descriptors, extraction, routing, translation, tool agents, classification
#   Vision → images + scanned/handwritten documents (Qwen-VL)
#
# MODEL_STACK selects the family: qwen (default) | glm | kimi | custom.
MODEL_STACK=qwen
# Extended thinking is model-agnostic: heavy reasoning calls get a larger output
# budget, and REASONING_EFFORT (low|medium|high) is forwarded as the OpenAI
# reasoning_effort hint for endpoints that support it (o-series, OpenRouter,
# DeepSeek-R1, …). Leave empty to omit it.
# REASONING_EFFORT=high
# DashScope international OpenAI-compatible endpoint (mainland: drop the -intl).
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
# Optional per-tier overrides (win over the stack preset):
# MODEL_HEAVY=qwen-max
# MODEL_MID=qwen-plus
# MODEL_LIGHT=qwen-turbo
# MODEL_VISION=qwen-vl-max
# Point any stack at an arbitrary OpenAI-compatible endpoint:
# PRIMARY_MODEL_URL=
# PRIMARY_MODEL_KEY=

# Omnimodal document extraction (Library upload). Text layer is ground truth;
# the vision model reconciles scans/tables/images. PDF page rasterization uses
# the bundled scripts/pdf_tools.py (Python 3.11+ + PyMuPDF, see requirements.txt)
# and degrades to text-layer-only when Python is absent.
# EXTRACT_VISION_MAX_PAGES=8       # max PDF pages rasterized + sent to the VLM per upload
# EXTRACT_VISION_MAX_TOKENS=4096   # cap on each vision/reconcile completion
# EXTRACT_SPARSE_PAGE_CHARS=80     # below this avg chars/page → treat PDF as scanned

# ─── Database / persistence ───────────────────────────────────────────────────
# Documents and attachment metadata persist through a storage seam. Default
# backend is a local pure-Go SQLite file (no cgo, Pi-friendly). Set DATABASE_URL
# to a postgres:// DSN for the cloud backend (e.g. Supabase, Neon, self-hosted)
# with database-level row-level security (RLS) under the app-layer checks.
DB_BACKEND=sqlite                       # sqlite (default) | postgres | memory
SQLITE_PATH=./data/biglaw.db
# DATABASE_URL=postgres://USER:PASS@HOST:5432/biglaw?sslmode=require
#
# RLS is DEFAULT-DENY (a request with no identity sees nothing). IMPORTANT: RLS
# only applies to NON-superuser roles — Postgres superusers (and roles with
# BYPASSRLS) skip it entirely even with FORCE. Connect as a plain app role.
# On Supabase, use a dedicated role (not the service_role, which bypasses RLS).

# Attachment blobs (retained original images/PDFs). Metadata (RLS-scoped) lives
# in the database; the bytes live in the blob store. All backends are open /
# vendor-neutral — AWS S3 is deliberately not offered.
BLOB_BACKEND=disk                       # disk (default) | webdav | supabase | oci
BLOB_DIR=./data/attachments             # disk backend root
# WebDAV (Nextcloud / ownCloud / Apache mod_dav / any RFC 4918 server):
# BLOB_WEBDAV_URL=https://dav.example.com/biglaw
# BLOB_WEBDAV_USER=
# BLOB_WEBDAV_PASS=
# Supabase Storage (native REST API, not S3 — open-source, self-hostable):
# BLOB_SUPABASE_URL=https://<ref>.supabase.co
# BLOB_SUPABASE_BUCKET=attachments
# BLOB_SUPABASE_KEY=
# OCI registry via ORAS (Zot / Distribution / Harbor / GHCR — "the open container thing"):
# BLOB_OCI_REF=registry.example.com/biglaw-attachments
# BLOB_OCI_USER=
# BLOB_OCI_PASS=
# BLOB_OCI_PLAIN_HTTP=false             # true for a local/insecure registry

# Embeddings (OpenAI; swap for Voyage AI: VOYAGE_API_KEY + model voyage-3-lite)
# Not required when LOCAL_EMBEDDINGS=true
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# OpenAI chat shortcut — run the whole bench on OpenAI's OpenAI-compatible API.
# Setting OPENAI_MODEL (with OPENAI_API_KEY above) routes chat through
# api.openai.com; embeddings use the same key. OPENAI_API_KEY alone (OPENAI_MODEL
# unset) powers only embeddings. OPENAI_TIERS narrows which agent tiers route to
# OpenAI (default: all). Spend is tracked automatically from the built-in rate
# table (see below) — gpt-5/4.1/4o and the embedding models are priced out of
# the box; only the gpt-5.5 flagship needs a rate set.
OPENAI_MODEL=
# OPENAI_TIERS=all

# Cost tracking — the built-in rate table prices the major global model families
# at early-2026 public list prices across OpenAI (gpt, embed), Google (gemini),
# DeepSeek, xAI (grok), Alibaba (qwen), Mistral, and Cohere. Version-drift IDs
# (e.g. deepseek-v3.1) resolve by family.
#
# A few stay untracked ($0.00) until you set a rate — no fabricated prices in the
# ledger: the gpt-5.5 flagship and the host-variable open-weight families
# (kimi/moonshot, glm, llama), whose price depends on which host serves them.
#
# Override ANY family to your negotiated/contract rate (USD per million tokens)
# with COST_<FAMILY>_IN / COST_<FAMILY>_OUT. One pair retargets every tier of
# the family at once. Families: GPT, EMBED, GEMINI, DEEPSEEK, GROK, QWEN,
# MISTRAL, COHERE, NOVA, KIMI, GLM, LLAMA, HAIKU, SONNET, OPUS.
# COST_GPT_IN=1.25      # e.g. set the gpt-5.5 flagship rate
# COST_GPT_OUT=10.00
# COST_DEEPSEEK_IN=0.27
# COST_DEEPSEEK_OUT=1.10
# COST_KIMI_IN=0.60
# COST_KIMI_OUT=2.50

# Local inference — Ollama (https://ollama.com)
# OLLAMA_ENABLED=true routes OLLAMA_TIERS agents to local Ollama.
# Pull a model first: ollama pull llama3.2
# For tool-use: ollama pull llama3.1   or  ollama pull qwen2.5
#
OLLAMA_ENABLED=false
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIERS=3
LOCAL_EMBEDDINGS=false
# Embedding model served by Ollama. Recommended: nomic-embed-text (768-dim)
# Also supported: mxbai-embed-large (1024-dim), or any Ollama-hosted model
LOCAL_EMBEDDING_MODEL=nomic-embed-text

# Generic local inference — any OpenAI-compat server (LM Studio, Jan, vLLM, llama.cpp)
# Set LOCAL_INFERENCE_URL to activate; LOCAL_INFERENCE_TIERS=all routes everything locally.
#
# LM Studio example:
#   LOCAL_INFERENCE_URL=http://localhost:1234/v1
#   LOCAL_INFERENCE_MODEL=llama-3.2-3b-instruct
#   LOCAL_INFERENCE_TIERS=all
#
# Jan example:
#   LOCAL_INFERENCE_URL=http://localhost:1337/v1
#   LOCAL_INFERENCE_MODEL=llama3-8b-instruct
#   LOCAL_INFERENCE_TIERS=2,3
#
# vLLM / llama.cpp server example:
#   LOCAL_INFERENCE_URL=http://gpu-server:8000/v1
#   LOCAL_INFERENCE_KEY=your-key-if-any
#   LOCAL_INFERENCE_MODEL=Meta-Llama-3.1-70B-Instruct
#   LOCAL_INFERENCE_TIERS=all
#
LOCAL_INFERENCE_URL=
LOCAL_INFERENCE_KEY=local
LOCAL_INFERENCE_MODEL=local-model
LOCAL_INFERENCE_TIERS=
# GPU power draw in watts — used to estimate watt-hours for local inference calls.
# 250 W = typical discrete GPU (RTX 3070–4090). 30 W = Apple Silicon. 65 W = CPU-only.
# LOCAL_INFERENCE_WATTS=250
# ISO 3166-1 alpha-2 country code for electricity cost + CO₂ per inference call.
# Looks up grid carbon intensity from CO2.js (Electricity Maps, 222 regions) and
# average commercial electricity price from IEA 2024 tariff data.
# Defaults to SEALAND (the North Sea micronation runs on diesel, no grid —
# unknown region falls back to world average 475 gCO₂/kWh). Set to your country.
# LOCAL_INFERENCE_REGION=GB

# PDF tools — PyMuPDF (text extraction + document generation) + Camelot (tables)
# System requirements: Python 3.11+, PyMuPDF >= 1.23, camelot-py[base]
# Install: pip install "pymupdf>=1.23" "camelot-py[base]"
# For bordered-table extraction (lattice mode): pip install "camelot-py[cv]"
PDF_PYTHON_BIN=python3
PDF_OUTPUT_DIR=./output/documents

# Vector DB (Qdrant dev stand-in; swap URL for RuVector: https://github.com/ruvnet/RuVector)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
# Set to true when QDRANT_URL points at a RuVector host to enable GNN self-learning feedback
RUVECTOR_ENABLED=false

# MCP / REST
MCP_PORT=3100
API_PORT=3101
# Bind the REST API to loopback by default (the API has no auth of its own).
# Set to 0.0.0.0 only behind a trusted proxy or with AUTH_ENABLED / API_KEY.
API_HOST=127.0.0.1
# Optional shared secret: when set, every request (except /health) must send it
# as the `x-api-key` header. Independent of the OAuth login below.
API_KEY=
# Profile bound to API_KEY. Callers cannot select identity with a header.
API_PROFILE_ID=

# ─── Run mode ───────────────────────────────────────────────────────────────
# The vector DB (./data) takes an exclusive single-writer lock and the REST API
# binds one port, so only ONE process can own them. To run a browse server and
# the Claude Code MCP at the same time, one owns the DB and the other attaches
# as a thin client over the REST API.
#   auto (default) own the DB if free; otherwise attach as an MCP client
#   backend        own DB + REST, never start MCP (a dedicated service: npm run serve)
#   mcp            pure MCP client — requires a reachable backend (errors if none)
#   standalone     classic single process (own DB + REST + MCP on stdio)
BIG_MICHAEL_MODE=auto
# URL an mcp/auto client connects to (defaults to the local API_HOST:API_PORT).
BIG_MICHAEL_API=

# ─── Authentication, sessions & access control ──────────────────────────────
# OFF by default → local dev runs with no login as a single "partner" who sees
# everything. Turn ON for shared/production deployments.
AUTH_ENABLED=false
# Required when AUTH_ENABLED=true; generate at least 32 random characters.
SESSION_SECRET=
# Browser origin(s) allowed by CORS (comma-separated). The UI's origin(s).
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
# Public URLs — this API (OAuth redirect base) and where to land after login.
PUBLIC_BASE_URL=http://localhost:3101
PUBLIC_UI_URL=http://localhost:5173
# Emails provisioned as `partner` (admin) on first login; everyone else `lawyer`.
ADMIN_EMAILS=
# OAuth apps — register one per provider you enable. Redirect URI:
#   <PUBLIC_BASE_URL>/auth/<provider>/callback   (google | microsoft | linkedin)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# DyTopo
DYTOPO_SIMILARITY_THRESHOLD=0.68
DYTOPO_MAX_AGENTS_PER_ROUND=12
DYTOPO_MAX_ROUNDS=14

# Debate protocol
DEBATE_CITATION_REQUIRED=true
DEBATE_ADVERSARIAL_ENABLED=true
DEBATE_VERIFICATION_PASSES=10
DEBATE_GATE_CONFIDENCE_THRESHOLD=0.80

# Web search (Tavily — https://tavily.com, free tier available)
TAVILY_API_KEY=

# Regulatory pulse monitor (auto-alerts for new rules affecting open matters)
REG_PULSE_ENABLED=false        # set to true to enable
REG_PULSE_INTERVAL_MS=604800000  # poll interval in ms (default: 7 days)
# TAVILY_API_KEY is already documented above — also enables regulatory pulse

# ─── Legal data connectors ───────────────────────────────────────────────────
# CourtListener — US case law, dockets, opinions (https://www.courtlistener.com/api/)
# Free and public. API key optional — unlocks higher rate limits.
COURT_LISTENER_API_KEY=
COURT_LISTENER_API_URL=https://www.courtlistener.com/api/rest/v4

# Ironclad — contract register (https://ironcladapp.com)
# Requires enterprise subscription. Set to activate ironclad_* agent tools.
IRONCLAD_API_KEY=
IRONCLAD_MCP_URL=https://mcp.na1.ironcladapp.com/mcp

# iManage — document management system (https://imanage.com)
# Requires iManage Cloud subscription. Set to activate imanage_* agent tools.
IMANAGE_API_KEY=
IMANAGE_MCP_URL=https://cloudimanage.com/mcp/work

# Definely — contract structure analysis (https://definely.com)
# Requires subscription. Set to activate definely_* agent tools.
DEFINELY_API_KEY=
DEFINELY_MCP_URL=https://mcp.uk.definely.com/api/proxy/core-mcp

# Westlaw / Thomson Reuters CoCounsel (https://legal-mcp.thomsonreuters.com)
# Requires Westlaw subscription. Set to activate westlaw_* agent tools.
WESTLAW_API_KEY=
WESTLAW_MCP_URL=https://legal-mcp.thomsonreuters.com/mcp

# Everlaw — e-discovery platform (https://everlaw.com)
# Requires Everlaw subscription. Set to activate everlaw_* agent tools.
EVERLAW_API_KEY=
EVERLAW_MCP_URL=https://api.everlaw.com/v1/mcp

# Trellis — state court case law dataset (https://trellis.law)
# Requires Trellis subscription. Set to activate trellis_* agent tools.
TRELLIS_API_KEY=
TRELLIS_MCP_URL=https://mcp.trellis.law/anthropic

# Descrybe — case law research (https://descrybe.com)
# Requires subscription. Set to activate descrybe_* agent tools.
DESCRYBE_API_KEY=
DESCRYBE_MCP_URL=https://mcp.descrybe.com/mcp

# DocuSign CLM — contract lifecycle management and envelope tracking (https://docusign.com)
# Requires DocuSign CLM subscription. Set to activate docusign_* agent tools.
DOCUSIGN_API_KEY=
DOCUSIGN_MCP_URL=https://mcp.docusign.com/mcp

# Solve Intelligence — AI patent drafting and prosecution (https://solveintelligence.com)
# Requires subscription. Set to activate solve_intelligence_* agent tools.
SOLVE_INTELLIGENCE_API_KEY=
SOLVE_INTELLIGENCE_MCP_URL=https://mcp.solveintelligence.com/mcp

# Slack — workspace search and internal messaging (https://slack.com)
# Requires Slack app with appropriate scopes. Set to activate slack_* agent tools.
SLACK_API_KEY=
SLACK_MCP_URL=https://mcp.slack.com/mcp

# Google Drive — VDR and matter document access (https://workspace.google.com)
# Requires Google service account or OAuth credentials. Set to activate google_drive_* tools.
GOOGLE_DRIVE_API_KEY=
GOOGLE_DRIVE_MCP_URL=https://mcp.googleapis.com/drive/mcp

# Box — VDR and matter room document access (https://box.com)
# Requires Box app credentials. Set to activate box_* agent tools.
BOX_API_KEY=
BOX_MCP_URL=https://api.box.com/mcp

# Lawve AI — contract review and clause library (https://lawve.ai)
# Requires subscription. Set to activate lawve_* agent tools.
LAWVE_API_KEY=
LAWVE_MCP_URL=https://api.lawve.ai/mcp

# TopCounsel — outside counsel panel routing (https://topcounsel.io)
# Requires subscription. Set to activate topcounsel_* agent tools.
TOPCOUNSEL_API_KEY=
TOPCOUNSEL_MCP_URL=https://api.topcounsel.io/mcp

# ─── Twenty — open-source CRM ───────────────────────────────────────────────
# Self-host: docker run -d -p 3000:3000 -v twenty_db:/app/.local-storage twentyhq/twenty
# Cloud:     https://app.twenty.com  (free tier available)
# API key:   Settings → API in the Twenty admin panel
#
# When both vars are set, Twenty tools are registered for agents and the
# following REST endpoints become active:
#   GET  /auth/twenty/status            — connection status
#   POST /clients/:id/sync-to-twenty    — upsert client as Twenty Company
#   POST /tasks/:id/push-to-twenty      — push synthesis note to a Company record
#
# Leave TWENTY_API_KEY blank to disable Twenty integration entirely.
TWENTY_API_URL=http://localhost:3000
TWENTY_API_KEY=

# ─── Clio practice management integration ────────────────────────────────────
# Full setup guide: see "Clio — getting started" in README.md
#
# 1. Register an OAuth app at https://app.clio.com/settings/developer_applications
# 2. Set Redirect URI to: <PUBLIC_BASE_URL>/auth/clio/callback
#    (default: http://localhost:3101/auth/clio/callback)
# 3. In the app settings, enable API access for:
#    Matters, Contacts, Documents, Activities (time entries), Notes, Users
# 4. Copy the Client ID and Client Secret below.
# 5. Set CLIO_REGION to match your firm's data region (us | eu | ca | au).
# 6. Start the server and have a partner visit GET /auth/clio/connect.
#
# Leave CLIO_CLIENT_ID blank to disable Clio integration entirely.
CLIO_CLIENT_ID=
CLIO_CLIENT_SECRET=
# Data region: us (default) | eu | ca | au
# Wrong region = 401 on every API call — must match where firm data is hosted.
CLIO_REGION=us
# Optional: space-separated OAuth scopes to declare in the authorization URL.
# Clio v4 defaults to the app's portal-configured permissions when omitted.
# Set if your Clio app requires explicit scope declaration.
# CLIO_SCOPES=
# Override redirect URI if your deployment uses a custom domain
# CLIO_REDIRECT_URI=http://localhost:3101/auth/clio/callback
# Token storage (default: ./data/clio-auth.json)
# CLIO_TOKENS_FILE=./data/clio-auth.json

# ─── Background job queue ────────────────────────────────────────────────────
# The queue bounds orchestrator task execution and also drives time-entry
# summarization and OCG bulk checks. Task submissions return 202 while queued.
# InMemoryQueue (default) persists jobs to JOBS_FILE and survives restarts.
# Switch to QUEUE_ADAPTER=redis (future) for horizontal K8s scaling via Redis
# Streams + KEDA. Set QUEUE_REDIS_URL to your Redis Streams endpoint.
#
QUEUE_CONCURRENCY=3
# Maximum waiting orchestrator tasks. This is a final safety boundary; normal
# load is queued instead of rejected.
QUEUE_MAX_PENDING=1000
QUEUE_POLL_INTERVAL_MS=2000
QUEUE_MAX_RETRIES=3
QUEUE_ADAPTER=memory
# QUEUE_REDIS_URL=redis://localhost:6379
# JOBS_FILE=.jobs.json

# Task persistence — path to JSON file for task state across restarts
TASKS_FILE=.tasks.json
PREBILLS_FILE=./data/prebills.json

# ─── LPM — Legal Project Management (daily status-report spine) ───────────────
# When enabled, a once-a-day scheduler (LPM_DAILY_HOUR, 24h local time; 6 = 0600)
# enqueues one durable job per active matter. A background worker generates a
# structured MatterStatusReport for each, appends it to an append-only corpus
# (LPM_CORPUS_FILE) and renders the configured formats into LPM_REPORT_DIR.
# JSON is the machine-readable harvest format; DOCX/Markdown are the human update.
LPM_ENABLED=false
LPM_DAILY_HOUR=6
LPM_REPORT_FORMATS=json,docx,markdown
LPM_CORPUS_FILE=./data/status-reports.jsonl
LPM_REPORT_DIR=./data/reports
# Synthesis model. Empty = low-power routing (Haiku, or Ollama/local if configured).
LPM_MODEL=
# Post a short summary + DOCX link to the matter's Teams/Slack channel.
LPM_CHANNEL_POST=false
# Email-writing power: off | channel | draft | send_gate. Every outbound draft
# is gated by the confidentiality guard (recipient-domain allowlist + leakage
# scan). send_gate never auto-sends — a human must approve via /lpm/draft/send.
LPM_EMAIL_WRITE_MODE=off
# Recipient-domain allowlist for outbound drafts (comma-separated; empty = none).
LPM_ALLOWED_DOMAINS=
# Email intake (Phase 2): shared_inbox | polling | both
LPM_INTAKE_MODE=polling
LPM_SHARED_INBOX=
LPM_POLL_INTERVAL_MIN=15
# Email→matter routing store + confidence floor (below = left unrouted).
LPM_ROUTED_FILE=./data/routed-emails.jsonl
LPM_ROUTE_MIN_CONFIDENCE=0.6
# send_gate pending-drafts store (queryable + approvable by ID).
LPM_PENDING_FILE=./data/pending-drafts.json

# Historical email backfill (Phase 4) — grinds old mail on cheap compute,
# resumable via a cursor and rate-limited so it can run for days unobtrusively.
LPM_BACKFILL_ENABLED=false
LPM_BACKFILL_WINDOW_DAYS=365
LPM_BACKFILL_STEP_DAYS=7
LPM_BACKFILL_MAX_PER_STEP=100
LPM_BACKFILL_PAUSE_MS=1000
LPM_BACKFILL_CURSOR_FILE=./data/backfill-cursor.json

# ─── Big Michael bots (Teams/Slack) ──────────────────────────────────────────
# Inbound webhook receivers (POST /bots/teams/webhook, /bots/slack/events),
# @BigMichael commands (status/report/portfolio/briefing/search/task/run), and
# task-completion notifications. Matter→channel links also load from
# TEAMS_MATTER_WEBHOOKS / SLACK_MATTER_CHANNELS (see below).
TEAMS_WEBHOOK_SECRET=
TEAMS_INCOMING_WEBHOOK_URL=
TEAMS_MATTER_WEBHOOKS=
TEAMS_ALLOWED_USER_IDS=
TEAMS_ALLOWED_TEAM_IDS=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_ALLOWED_USER_IDS=
SLACK_DEFAULT_CHANNEL=
SLACK_MATTER_CHANNELS=

# ─── Firm-wide background monitors ───────────────────────────────────────────
# Budget threshold alerts (uses matter budgets), court-docket polling
# (CourtListener), and the regulatory pulse (auto-enables only with TAVILY_API_KEY).
# Alerts post to the matter channel (if linked) and the audit log.
MONITOR_BUDGET_ALERTS=true
MONITOR_BUDGET_INTERVAL_MIN=60
MONITOR_DOCKETS=true
MONITOR_DOCKET_INTERVAL_MIN=30
DOCKETS_FILE=./data/dockets.json
MONITOR_REGULATORY_INTERVAL_MIN=360

# Audit log — append-only JSONL; every inference call, tool call, gate, debate is recorded
# Set AUDIT_ENABLED=false to disable disk writes (in-memory buffer always active)
AUDIT_ENABLED=true
AUDIT_LOG_FILE=./audit.jsonl

# ─── Audit sinks (optional) ──────────────────────────────────────────────────
# Each sink is independent. Set the required vars to activate.
# All URLs are SSRF-validated (http/https only). Credentials are never logged.
#
# OpenSearch (self-hosted, recommended):
#   docker compose --profile audit up -d   → starts OpenSearch + Dashboards
#   Audit events land in big-michael-audit-YYYY.MM (monthly rollover).
# AUDIT_OPENSEARCH_URL=http://localhost:9200
# AUDIT_OPENSEARCH_API_KEY=
#
# Splunk HEC:
#   Requires a Splunk HTTP Event Collector token.
#   Set sourcetype "big_michael:audit" in your Splunk index policy.
# AUDIT_SPLUNK_HEC_URL=https://splunk.example.com:8088
# AUDIT_SPLUNK_HEC_TOKEN=
# AUDIT_SPLUNK_INDEX=
#
# Generic webhook (Datadog, Azure Monitor, custom SIEM):
#   POSTs each event as JSON. Optional Bearer token for auth.
# AUDIT_WEBHOOK_URL=
# AUDIT_WEBHOOK_TOKEN=

# ─── Agent billing ───────────────────────────────────────────────────────────
# AI agents record billable time entries attributed to the responsible lawyer.
# All rates are USD/hour. Default 0 = opt-in (no entries created at 0 rate).
# Per-agent overrides: set billingRate on individual AgentDefinitions in definitions.ts.
#
# AGENT_BILLING_ENABLED=true          # set false to disable the feature entirely
# AGENT_BILLING_RATE_DEFAULT=0        # fallback rate for all tiers
# AGENT_BILLING_RATE_T0=0             # root orchestrator tier
# AGENT_BILLING_RATE_T1=0             # domain manager tier
# AGENT_BILLING_RATE_T2=0             # specialist / drafting / conceptual agents
# AGENT_BILLING_RATE_T3=0             # tool agents (web search, extraction, etc.)

# ─── DocuSeal — open-source e-signature ─────────────────────────────────────
# Self-host: docker run -d -p 3000:3000 docuseal/docuseal
# Cloud:     https://app.docuseal.com  (free tier available)
# API key:   Settings → API in the DocuSeal admin panel
DOCUSEAL_URL=http://localhost:3000
DOCUSEAL_API_KEY=

# ─── Infisical — open-source secrets manager ─────────────────────────────────
# The ONLY vars that need to be here (or in host env) for a production deploy.
# Everything else lives in Infisical and is injected before app code runs.
#
# Self-host (recommended for law firms — keeps secrets on-prem):
#   git clone https://github.com/Infisical/infisical && cd infisical
#   docker compose -f docker-compose.prod.yml up -d
#   # Then visit http://localhost:80 to set up your project
#
# Cloud: https://app.infisical.com (open-source, free tier)
#
# Setup:
#   1. Create a project in Infisical
#   2. Access Control → Machine Identities → New Identity (Universal Auth)
#   3. Copy Client ID and Client Secret into INFISICAL_CLIENT_ID/SECRET below
#   4. Add ALL secrets (QWEN_API_KEY, connector keys, SESSION_SECRET, etc.)
#      as project secrets in Infisical
#   5. Delete those keys from this file — they will be loaded at startup
#
# How it works: index.ts awaits loadSecrets() before any dynamic import() of
# application code, so config.ts's require() calls see Infisical-injected values.
#
INFISICAL_URL=https://app.infisical.com
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_PROJECT_ID=
INFISICAL_ENV=production
INFISICAL_PATH=/

# ─── TypeDB conflict graph (optional) ────────────────────────────────────────
# Enables multi-hop conflict-of-interest detection using TypeDB's logic-
# programming inference rules. Detects conflicts that flat substring matching
# cannot: Client A adverse to B, B subsidiary of C, we represent C → conflict.
#
# Setup:
#   docker compose --profile graph up -d   (starts TypeDB on port 1729)
#   Then set TYPEDB_URL below.
#
# Leave blank to disable — all graph methods are no-ops, server starts normally.
TYPEDB_URL=          # e.g. 0.0.0.0:1729; empty = TypeDB disabled

# Docket monitoring (new CourtListener filings → auto-ingest + SSE alert)
DOCKET_MONITOR_ENABLED=false    # set to true to enable
DOCKET_POLL_INTERVAL_MS=14400000  # 4 hours
DOCKETS_FILE=./data/dockets.json

# Logging
LOG_LEVEL=info
